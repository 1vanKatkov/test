APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=https://your-public-domain.example
APP_TITLE=Mini App + Web Services for Telegram and MAX
RUN_TELEGRAM_BOT=true
RUN_TELEGRAM_BOT_EN=true
RUN_MAX_BOT=true

# Dev-only auth bypass for testing "authorized" flows without MAX/Telegram signatures.
# NEVER enable in production.
DEV_AUTH_BYPASS=false
DEV_AUTH_MOCK_PROVIDER_USER_ID=dev-bypass-user
DEV_AUTH_MOCK_USERNAME=Dev Tester
DEV_AUTH_MOCK_LANGUAGE=ru
EMAIL_AUTH_SECRET=put_random_email_auth_secret_here
EMAIL_AUTH_TTL_SECONDS=2592000
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_USER_EMAIL=
SEED_USER_PASSWORD=
SEED_USER_NAME=User

TELEGRAM_BOT_TOKEN=put_telegram_bot_token_here
TELEGRAM_BUTTON_TEXT=Open mini app
TELEGRAM_BOT_TOKEN_EN=put_english_telegram_bot_token_here
TELEGRAM_BUTTON_TEXT_EN=Open app

MAX_BOT_TOKEN=put_max_bot_token_here
MAX_API_BASE_URL=https://api.max.example
MAX_BUTTON_TEXT=Open mini app
MAX_POLLING_ENABLED=true

# Web services (sonnik, numerology, sovmestimost)
DATABASE_PATH=./data/sonnik_users.db
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
# Required for AI endpoints:
# - /api/sonnik/interpret
# - /api/sovmestimost/by-names
# - /api/sovmestimost/by-names-dates
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key
MODEL_SONNIK=@preset/sonnik
MODEL_SOVMESTIMOST=@preset/sovmestimost
STARTING_CREDITS=10
COST_SONNIK=5
COST_NUMEROLOGY=5
COST_SOVMESTIMOST=5
# Telegram Mini App server-side auth
TELEGRAM_AUTH_SKEW_SECONDS=86400
# YooKassa payments
YOOKASSA_SHOP_ID=put_shop_id_here
YOOKASSA_SECRET_KEY=put_secret_key_here
YOOKASSA_RETURN_URL=https://t.me/your_bot_username
# Required for accounts that must send online receipt (54-FZ):
YOOKASSA_RECEIPT_EMAIL=payments@your-domain.example
# VAT code for receipt item (1..6). Common default: 1
YOOKASSA_VAT_CODE=1
# SDK request timeout to YooKassa in seconds (default SDK is 1800s, too high for web)
YOOKASSA_TIMEOUT_SECONDS=20
# Number of SDK retry attempts per request
YOOKASSA_MAX_ATTEMPTS=1
# Required only for explicit MAX signature verification endpoint: /api/auth/max/verify
MAX_AUTH_SECRET=put_max_auth_secret_here
MAX_AUTH_SKEW_SECONDS=300

# Optional path overrides
NUMEROLOGY_DIR=./bots228/numerology
SOVMESTIMOST_MESSAGES_PATH=./bots228/sovmestimost/messages.json
REPORTS_DIR=./app/reports
